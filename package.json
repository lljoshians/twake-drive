{
  "name": "twake-drive",
  "version": "1.0.0",
  "description": "Twake Drive - A collaborative file storage and sharing platform",
  "private": true,
  "workspaces": [
    "tdrive/frontend",
    "tdrive/backend/node"
  ],
  "scripts": {
    "start": "yarn workspace twake-drive-frontend start",
    "build": "yarn workspace twake-drive-frontend build",
    "test": "yarn workspaces run test",
    "test:frontend": "yarn workspace twake-drive-frontend test",
    "test:backend": "yarn workspace twake-drive-backend test",
    "lint": "yarn workspaces run lint",
    "lint:fix": "yarn workspaces run lint:fix",
    "bundlemon": "bundlemon",
    "prepare": "husky install",
    "clean": "rm -rf node_modules tdrive/frontend/node_modules tdrive/backend/node/node_modules"
  },
  "devDependencies": {
    "bundlemon": "^2.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/linagora/twake-drive.git"
  },
  "license": "AGPL-3.0"
}
